# ——— Lernzit site configuration ———
# Copy to .env.local for local development; set the same variables in Vercel for production.

# Public site URL (used for sitemap, OpenGraph, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://lernzit.com

# Official Amazon brand page (every "Shop on Amazon" button)
NEXT_PUBLIC_AMAZON_STORE_URL=https://www.amazon.com/stores/Lernzit

# WordPress REST API root — set this once WP is installed on Hostinger.
# Leave unset to use the local sample posts in content/sample-posts/.
# WP_API_URL=https://cms.lernzit.com/wp-json/wp/v2

# Google Analytics 4 measurement ID (analytics load only when set)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console verification token (meta tag renders only when set)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxx

# Contact form delivery via Formspree (https://formspree.io, free tier).
# Without it, form submissions are logged to the server console.
# FORMSPREE_ENDPOINT=https://formspree.io/f/xxxxxxxx
